# D&D Character Forge - Production Environment Variables
# Copy this file to .env and fill in the values.

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database
DB_NAME=dnd_forge
DB_USER=dnd_user
DB_PASSWORD=change-me-to-a-strong-password

# CORS and CSRF (comma-separated origins)
CORS_ALLOWED_ORIGINS=https://yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# Frontend build
VITE_API_URL=/api

# Gunicorn workers (recommended: 2 * CPU cores + 1)
GUNICORN_WORKERS=3

# Port to expose Nginx on the host
PORT=80
